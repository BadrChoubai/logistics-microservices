{
    "swagger": "2.0",
    "info": {
        "description": "Telemetry Service for the Logistics Services API platform",
        "title": "Telemetry Service",
        "contact": {},
        "version": "1.0.0"
    },
    "host": "localhost:8083",
    "basePath": "/",
    "paths": {
        "/health": {
            "get": {
                "description": "Returns service health check response",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.HealthcheckResponse"
                        }
                    }
                }
            },
            "head": {
                "description": "Returns service health check response",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.HealthcheckResponse"
                        }
                    }
                }
            }
        },
        "/readings": {
            "get": {
                "description": "Returns a sensor reading",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "telemetry"
                ],
                "summary": "Get Sensor Reading",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.TelemetryReading"
                        }
                    }
                }
            },
            "post": {
                "description": "Returns a sensor reading",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "telemetry"
                ],
                "summary": "Ingest Sensor Reading",
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/handler.TelemetryReading"
                        }
                    }
                }
            }
        },
        "/readings/{shipment_id}": {
            "get": {
                "description": "Returns telemetry data for a given shipment",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "telemetry"
                ],
                "summary": "Get sensor reading for a Shipment",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "list"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handler.HealthcheckResponse": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "string"
                },
                "version": {
                    "type": "string"
                }
            }
        },
        "handler.TelemetryReading": {
            "type": "object"
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}